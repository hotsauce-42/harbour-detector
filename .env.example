# Copy this file to .env and fill in your credentials.
# .env is never committed (see .gitignore).
#
# Values in config/settings.yaml [s3] section take precedence over these.
# These env vars are the fallback when the YAML fields are left blank.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# For MinIO or other S3-compatible endpoints:
S3_ENDPOINT_URL=http://localhost:9000
